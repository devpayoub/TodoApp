---
import TodoInput from './TodoInput.astro';
import CategorySystem from './CategorySystem.astro';
import TodoList from './TodoList.astro';
---

<div class="todo-container">
  <a href="#todo-main-content" class="skip-link">Skip to main content</a>

  <header class="app-header">
    <div class="logo-area">
      <span class="vrcafe-vr">VR</span><span class="vrcafe-cafe">cafe</span>
      <span class="logo-sub">Todo App</span>
    </div>
    <div class="app-stats">
      <span id="completion-counter" aria-live="polite">0 / 0 completed</span>
    </div>
  </header>

  <div class="app-layout">
    <aside class="sidebar">
      <CategorySystem />
    </aside>

    <main id="todo-main-content" class="main-panel" tabindex="-1">
      <h2 id="current-category-heading" class="panel-heading">All Tasks</h2>
      <TodoInput />
      <TodoList />
    </main>
  </div>

  <div id="sr-announcer" class="sr-only" aria-live="polite" role="status"></div>
</div>

<script>
  import '../scripts/todo-controller.ts';
</script>
